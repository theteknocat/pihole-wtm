# ============================================================
# pihole-wtm configuration
# Copy this file to .env and fill in your values.
# ============================================================

# --- Pi-hole connection ---

# Connection mode: "api" (HTTP API) or "sqlite" (direct DB access)
PIHOLE_MODE=api

# Pi-hole API mode: URL and password
PIHOLE_API_URL=http://pihole
PIHOLE_API_PASSWORD=your_password_here
# Pi-hole API version: "v5", "v6", or "auto" (default: auto-detect)
PIHOLE_API_VERSION=auto

# Pi-hole SQLite mode: path to pihole-FTL.db
# (mount the file read-only into the container, then set this path)
PIHOLE_SQLITE_PATH=/etc/pihole/pihole-FTL.db

# --- TrackerDB ---
TRACKERDB_UPDATE_INTERVAL_HOURS=24

# --- Docker deployment ---

# Port to expose the dashboard on the host
DASHBOARD_PORT=8080

# Docker network that Pi-hole is connected to (for API mode)
PIHOLE_NETWORK=pihole_default
