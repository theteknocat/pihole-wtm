# ============================================================
# pihole-wtm configuration
# Copy this file to .env and fill in your values.
# ============================================================

# --- Pi-hole connection ---
# Both are optional for initial testing (you can log in via the UI instead),
# but recommended for production to enable always-on background sync.

# URL of your Pi-hole web interface
PIHOLE_API_URL=http://pihole

# Pi-hole admin password — enables continuous sync without needing to be logged in
PIHOLE_API_PASSWORD=

# --- Optional ---

# How many hours before an idle dashboard session expires (default: 24)
# SESSION_TIMEOUT_HOURS=24

# Log level: debug, info, warning, error, critical (default: info)
# LOG_LEVEL=info
