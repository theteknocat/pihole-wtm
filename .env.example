# ============================================================
# pihole-wtm configuration
# Copy this file to .env and fill in your values.
# ============================================================

# --- Pi-hole connection (HTTP API) ---

# URL of your Pi-hole web interface (optional — can also be set via the login page)
PIHOLE_API_URL=http://pihole

# API version: "v5", "v6", or "auto" (default: auto-detect)
PIHOLE_API_VERSION=auto

# --- Session ---
# How many hours before an idle session expires (default: 24)
# SESSION_TIMEOUT_HOURS=24

# --- TrackerDB ---
TRACKERDB_UPDATE_INTERVAL_HOURS=24

# --- Data retention ---
# Number of days to keep query data (older data is purged each sync cycle)
DATA_RETENTION_DAYS=7

# --- Logging ---
# Log level: debug, info, warning, error, critical
LOG_LEVEL=info

# --- Docker deployment ---

# Port to expose the dashboard on the host
DASHBOARD_PORT=8080

# Docker network that Pi-hole is connected to
PIHOLE_NETWORK=pihole_default
