#!/bin/bash
if git diff-tree -r --name-only --no-commit-id ORIG_HEAD HEAD | grep -q "backend/pyproject.toml"; then
  if ddev describe 2>/dev/null | grep -q "running"; then
    echo "pyproject.toml changed — reinstalling Python package in ddev..."
    ddev exec -d /var/www/html/backend .venv/bin/uv pip install -e '.[dev]' --quiet
    echo "Done."
  else
    echo "pyproject.toml changed — run 'ddev restart' to pick up the new version."
  fi
fi
